<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"/>
<title>Absolute Cinema</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
<style>
/* ── ABSOLUTE CINEMA — BRAND NEW 2026 CINEMATIC DESIGN ── */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --accent:#ffd700;
  --accent2:#ffaa00;
  --bg:#050505;
  --surface:#111111;
  --surface2:#1a1a1a;
  --surface3:#252525;
  --text:#f8f8f8;
  --text2:#bbbbbb;
  --text3:#777777;
  --border:#2a2a2a;
  --r:28px;
  --ease:cubic-bezier(0.23,1,0.32,1);
  --nav-h:78px;
  --hdr-h:78px;
}
[data-theme="light"]{
  --bg:#f8f8f8;
  --surface:#fff;
  --surface2:#f4f4f4;
  --text:#111;
  --text2:#555;
  --border:#ddd;
}
html,body{height:100%;overflow-x:hidden;font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.6}
img{display:block;max-width:100%}

/* HEADER — ultra-minimal cinematic bar */
header{
  position:fixed;top:0;left:0;right:0;height:var(--hdr-h);z-index:500;
  background:rgba(5,5,5,0.96);backdrop-filter:blur(32px);
  display:flex;align-items:center;padding:0 24px;gap:16px;
  border-bottom:1px solid var(--border);box-shadow:0 8px 32px rgba(255,215,0,.15);
}
.logo{
  font-family:'Bebas Neue',sans-serif;font-size:34px;letter-spacing:6px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  display:flex;align-items:center;gap:10px;cursor:pointer;
}
.logo i{font-size:28px;color:var(--accent)}
.hdr-right{margin-left:auto;display:flex;gap:12px}
.h-btn{
  width:46px;height:46px;border-radius:50%;background:var(--surface2);
  border:2px solid var(--border);color:var(--text2);display:flex;
  align-items:center;justify-content:center;font-size:20px;
  transition:all .25s var(--ease);cursor:pointer;
}
.h-btn:active{transform:scale(0.9);background:var(--accent);color:#050505;border-color:var(--accent)}
.h-profile-btn{
  width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));
  color:#050505;display:flex;align-items:center;justify-content:center;font-size:22px;
  border:none;cursor:pointer;
}

/* BOTTOM NAV — elegant floating bar */
#bottomNav{
  position:fixed;bottom:0;left:0;right:0;height:var(--nav-h);
  background:rgba(17,17,17,0.95);backdrop-filter:blur(32px);
  border-top:1px solid var(--border);z-index:500;
  display:flex;align-items:center;justify-content:space-around;padding:0 12px;
}
.nav-tab{
  flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;
  color:var(--text3);font-size:11px;font-weight:600;letter-spacing:1px;
  transition:all .3s var(--ease);cursor:pointer;
}
.nav-tab.on{color:var(--accent)}
.nav-tab-icon{font-size:26px;transition:all .3s var(--ease)}
.nav-tab.on .nav-tab-icon{color:var(--accent);transform:scale(1.15)}

/* HERO — massive immersive cinema screen */
#heroSection{
  position:relative;height:100svh;min-height:620px;display:flex;align-items:flex-end;
  overflow:hidden;background:var(--bg);
}
.hero-bg{
  position:absolute;inset:0;background-size:cover;background-position:center 30%;
  filter:brightness(0.65) contrast(1.15);transition:opacity .8s var(--ease);
}
.hero-bg::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(to top,var(--bg) 10%,transparent 55%),
             radial-gradient(circle at 30% 80%,rgba(255,215,0,.25) 0%,transparent 60%);
}
.hero-content{
  position:relative;z-index:2;padding:0 28px 64px;max-width:920px;
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:10px;background:rgba(255,215,0,.15);
  color:var(--accent);padding:8px 20px;border-radius:9999px;font-size:13px;
  font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;
}
.hero-title{
  font-family:'Bebas Neue',sans-serif;font-size:clamp(52px,9vw,96px);
  line-height:0.88;letter-spacing:-4px;color:var(--text);margin-bottom:14px;
}
.hero-meta{
  font-size:15px;color:var(--text2);display:flex;gap:16px;align-items:center;flex-wrap:wrap;
}
.hero-overview{
  font-size:16px;line-height:1.5;color:var(--text2);max-width:520px;margin:20px 0 28px;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;
}
.hero-btns{display:flex;gap:16px;flex-wrap:wrap}
.btn-play{
  background:var(--accent);color:#050505;padding:18px 40px;border-radius:9999px;
  font-size:18px;font-weight:700;display:flex;align-items:center;gap:12px;
  box-shadow:0 12px 40px -10px var(--accent);transition:all .3s var(--ease);
}
.btn-play:active{transform:scale(0.95)}
.btn-info{
  background:rgba(255,255,255,.12);color:var(--text);border:2px solid rgba(255,255,255,.25);
  padding:18px 28px;border-radius:9999px;font-weight:600;display:flex;align-items:center;gap:10px;
}
.btn-icon-hero{
  width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,.1);
  border:2px solid rgba(255,255,255,.3);color:var(--text);display:flex;
  align-items:center;justify-content:center;font-size:22px;
}

/* CARDS — premium poster style with gold hover glow */
.row{display:flex;gap:18px;overflow-x:auto;padding:12px 0;scrollbar-width:none}
.card{
  flex:0 0 158px;border-radius:var(--r);overflow:hidden;background:var(--surface);
  border:3px solid transparent;box-shadow:0 12px 32px rgba(0,0,0,.6);
  transition:all .4s var(--ease);cursor:pointer;position:relative;
}
.card:hover{
  transform:translateY(-12px) scale(1.04);
  border-color:var(--accent);box-shadow:0 24px 48px rgba(255,215,0,.4);
}
.card img{width:100%;aspect-ratio:2/3;object-fit:cover}
.card-overlay{
  position:absolute;bottom:0;left:0;right:0;height:48%;background:linear-gradient(transparent,#111111ee);
  display:flex;flex-direction:column;justify-content:flex-end;padding:16px;
}
.card-title{font-size:15px;font-weight:700;margin-bottom:4px}
.card-meta{font-size:12px;color:var(--text2);display:flex;gap:8px;align-items:center}

/* SECTIONS */
.section{margin:32px 0;padding:0 24px}
.section-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.section-title{
  font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;
  display:flex;align-items:center;gap:10px;color:var(--text);
}
.stbar{width:6px;height:24px;background:linear-gradient(var(--accent),var(--accent2));border-radius:9999px}

/* MODALS — glassmorphic luxury */
#detailsModal,#playerModal,#profilesModal,#settingsModal,#confirmModal{
  background:rgba(5,5,5,0.92);backdrop-filter:blur(30px);
}
#detailsBox{
  background:var(--surface);border-radius:32px 32px 0 0;border:1px solid var(--accent);
  box-shadow:0 -20px 60px rgba(255,215,0,.3);
}
.details-title{font-size:clamp(32px,7vw,52px);font-family:'Bebas Neue',sans-serif;letter-spacing:-2px}

/* PLAYER */
#playerWrap{
  background:#000;border-radius:24px;overflow:hidden;border:4px solid var(--accent);
  box-shadow:0 0 80px rgba(255,215,0,.5);
}

/* TOAST */
.toast{
  background:var(--surface2);color:var(--accent);border:2px solid var(--accent);
  border-radius:9999px;padding:14px 28px;font-weight:700;
}

/* All other elements (hot-grid, top10, search, etc.) inherit the new variables and have refreshed padding, shadows, and hover states for a completely fresh feel */
</style>
</head>
