<style>
/* ── ABSOLUTE CINEMA — 2026 CINEMATIC REDESIGN ── */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --accent:#ffd700;--accent2:#ffaa00;
  --bg:#0a0a0a;--bg2:#111111;--surface:#1a1a1a;--surface2:#222222;--surface3:#2a2a2a;
  --text:#f8f8f8;--text2:#cccccc;--text3:#888888;
  --border:#333333;--border2:#444444;
  --r:24px;--ease:cubic-bezier(0.23,1,0.32,1);
  --nav-h:76px;--hdr-h:76px;
}
[data-theme="light"]{--bg:#f8f8f8;--surface:#ffffff;--text:#111111;--text2:#555555;--border:#eeeeee}

html,body{height:100%;overflow-x:hidden;font-family:'Inter',sans-serif;background:var(--bg);color:var(--text)}
img{display:block}

/* HEADER */
header{position:fixed;top:0;left:0;right:0;height:var(--hdr-h);z-index:500;background:rgba(10,10,10,0.95);backdrop-filter:blur(32px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:16px;box-shadow:0 10px 30px rgba(255,215,0,.2)}
.logo{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:4px;background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:flex;align-items:center;gap:10px;cursor:pointer}
.logo i{font-size:32px}
.hdr-right{margin-left:auto;display:flex;gap:12px}
.h-btn{width:48px;height:48px;border-radius:50%;background:var(--surface);border:2px solid var(--border);color:var(--text2);display:flex;align-items:center;justify-content:center;font-size:21px;transition:all .3s var(--ease)}
.h-btn:active{transform:scale(0.92);background:var(--accent);color:#0a0a0a;border-color:var(--accent)}
.h-profile-btn{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#0a0a0a;display:flex;align-items:center;justify-content:center;font-size:24px;border:none}

/* BOTTOM NAV */
#bottomNav{position:fixed;bottom:0;left:0;right:0;height:var(--nav-h);background:rgba(26,26,26,0.95);backdrop-filter:blur(32px);border-top:1px solid var(--border);z-index:500;display:flex;align-items:center;justify-content:space-around}
.nav-tab{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;color:var(--text3);font-size:11px;font-weight:700;letter-spacing:1px;transition:all .3s var(--ease)}
.nav-tab.on{color:var(--accent)}
.nav-tab-icon{font-size:27px}
.nav-tab.on .nav-tab-icon{transform:scale(1.2)}

/* HERO */
#heroSection{height:100svh;min-height:640px;display:flex;align-items:flex-end;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center 25%;filter:brightness(0.7) contrast(1.1)}
.hero-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(to top,#0a0a0a 8%,transparent 60%),radial-gradient(circle at 40% 70%,rgba(255,215,0,.35) 0%,transparent 70%)}
.hero-content{position:relative;z-index:2;padding:0 28px 72px}
.hero-eyebrow{display:inline-flex;align-items:center;gap:12px;background:rgba(255,215,0,.2);color:var(--accent);padding:8px 24px;border-radius:9999px;font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,9vw,98px);line-height:0.9;letter-spacing:-4px;margin-bottom:12px}
.hero-meta{font-size:15px;color:var(--text2);display:flex;gap:18px}
.hero-overview{font-size:16.5px;line-height:1.55;color:var(--text2);max-width:560px;margin:24px 0 32px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.btn-play{background:var(--accent);color:#0a0a0a;padding:18px 42px;border-radius:9999px;font-size:18px;font-weight:700;display:flex;align-items:center;gap:14px;box-shadow:0 20px 40px -10px var(--accent);transition:all .3s var(--ease)}
.btn-play:active{transform:scale(0.95)}
.btn-info{background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.3);color:var(--text);padding:18px 32px;border-radius:9999px;font-weight:600;display:flex;align-items:center;gap:12px}

/* CARDS & ROWS */
.row{display:flex;gap:18px;overflow-x:auto;padding:10px 0;scrollbar-width:none}
.card{flex:0 0 164px;border-radius:28px;overflow:hidden;background:var(--surface);border:3px solid transparent;box-shadow:0 20px 40px rgba(0,0,0,.7);transition:all .4s var(--ease);cursor:pointer}
.card:hover{transform:translateY(-14px) scale(1.06);border-color:var(--accent);box-shadow:0 30px 60px rgba(255,215,0,.5)}
.card img{width:100%;aspect-ratio:2/3;object-fit:cover}
.card-overlay{position:absolute;bottom:0;left:0;right:0;height:52%;background:linear-gradient(transparent,#111111ee);display:flex;flex-direction:column;justify-content:flex-end;padding:18px}
.card-title{font-size:15px;font-weight:700}
.card-meta{font-size:12px;color:var(--text2);display:flex;gap:8px}

/* SECTIONS */
.section{margin:36px 0;padding:0 24px}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:4px;display:flex;align-items:center;gap:12px}
.stbar{width:7px;height:26px;background:linear-gradient(var(--accent),var(--accent2));border-radius:9999px}

/* MODALS & PLAYER — glass + gold glow */
#detailsModal,#playerModal,#profilesModal,#settingsModal,#confirmModal,#searchOverlay,#starAppsPopup{background:rgba(10,10,10,0.94);backdrop-filter:blur(40px)}
#detailsBox,#playerWrap{border:3px solid var(--accent);box-shadow:0 0 80px rgba(255,215,0,.6)}
#playerWrap{border-radius:28px}
.toast{background:var(--surface);border:2px solid var(--accent);color:var(--accent);border-radius:9999px;padding:16px 32px;font-weight:700}

/* Keep all your original classes working — only visual changes above */
</style>
</head>
